name: Convertir ZIP en APK

on:
  push:
    branches: [ "main" ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: 1. Recuperer le code du depot
        uses: actions/checkout@v4

      - name: 2. Creer le dossier de travail
        run: mkdir -p build_folder

      - name: 3. Decompresser le fichier ZIP
        run: unzip Salut.zip -d build_folder

      - name: 4. Ajuster le nom du fichier HTML pour l'APK
        run: |
          cd build_folder
          if [ -f "photo-swipe-sorter.html" ]; then
            cp "photo-swipe-sorter.html" "index.html"
          fi

      - name: 5. Compiler les fichiers en APK
        uses: darkshredder/website-to-apk-action@v2.0.1
        with:
          build-folder-path: "build_folder/"
          app-name: "PhotoSorter"
          output-folder-path: "output/"

      - name: 6. Telecharger l'APK genere
        uses: actions/upload-artifact@v4
        with:
          name: Mon-APK-PhotoSorter
          path: output/

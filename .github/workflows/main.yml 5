name: Convertir HTML en APK

on:
  push:
    branches: [ "main" ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: 1. Recuperer le code du depot
        uses: actions/checkout@v4

      - name: 2. Installer Java 17 (Requis pour Gradle)
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '17'

      - name: 3. Initialiser un projet Android natif minimal
        run: |
          mkdir -p android-project/app/src/main/assets/www
          mkdir -p android-project/app/src/main/java/com/photosorter/app
          
          # Extraction du ZIP dans le dossier web de l'application
          unzip Salut.zip -d android-project/app/src/main/assets/www/
          
          # Correction du fichier d'accueil (on force index.html)
          cd android-project/app/src/main/assets/www
          if [ -f "photo-swipe-sorter.html" ]; then
            cp "photo-swipe-sorter.html" "index.html"
          fi
          cd '../../../../../../'

      - name: 4. Creer les fichiers de configuration Android
        run: |
          # Fichier build.gradle racine
          cat << 'EOF' > android-project/build.gradle
          buildscript {
              repositories { google() { content { includeGroupAndSubgroups("com.android") } }; mavenCentral() }
              dependencies { classpath 'com.android.tools.build:gradle:8.2.2' }
          }
          allprojects { repositories { google(); mavenCentral() } }
          EOF

          # Fichier settings.gradle
          echo "include ':app'" > android-project/settings.gradle

          # Fichier build.gradle de l'application
          cat << 'EOF' > android-project/app/build.gradle
          plugins { id 'com.android.application' }
          android {
              namespace 'com.photosorter.app'
              compileSdk 34
              defaultConfig {
                  applicationId "com.photosorter.app"
                  minSdk 21
                  targetSdk 34
                  versionCode 1
                  versionName "1.0"
              }
          }
          EOF

          # Fichier AndroidManifest.xml (Autorise Internet et configure l'affichage)
          cat << 'EOF' > android-project/app/src/main/AndroidManifest.xml
          <manifest xmlns:android="http://schemas.android.com/apk/and/android">
              <uses-permission android:name="android.permission.INTERNET"/>
              <application android:label="PhotoSorter" android:theme="@android:style/Theme.NoTitleBar.Fullscreen">
                  <activity android:name=".MainActivity" android:exported="true">
                      <intent-filter>
                          <action android:name="android.intent.action.MAIN"/>
                          <category android:name="android.intent.category.LAUNCHER"/>
                      </intent-filter>
                  </activity>
              </application>
          </manifest>
          EOF

          # Code Java pour charger ton fichier HTML dans l'application
          cat << 'EOF' > android-project/app/src/main/java/com/photosorter/app/MainActivity.java
          package com.photosorter.app;
          import android.app.Activity;
          import android.os.Bundle;
          import android.webkit.WebView;
          import android.webkit.WebViewClient;

          public class MainActivity extends Activity {
              @Override
              protected void onCreate(Bundle savedInstanceState) {
                  super.onCreate(savedInstanceState);
                  WebView webView = new WebView(this);
                  webView.getSettings().setJavaScriptEnabled(true);
                  webView.getSettings().setAllowFileAccess(true);
                  webView.getSettings().setAllowContentAccess(true);
                  webView.setWebViewClient(new WebViewClient());
                  webView.loadUrl("file:///android_asset/www/index.html");
                  setContentView(webView);
              }
          }
          EOF

      - name: 5. Compiler l'APK avec Gradle
        run: |
          cd android-project
          chmod +x ../
          gradle wrapper --gradle-version 8.5
          ./gradlew assembleRelease

      - name: 6. Telecharger l'APK genere (Version moderne v4)
        uses: actions/upload-artifact@v4
        with:
          name: Mon-APK-PhotoSorter
          path: android-project/app/build/outputs/apk/release/app-release-unsigned.apk
